# ---------------------------------------------------------------------------
# The Realty App — environment variables
# Copy this file to .env.local for local dev, and set the same values in
# Vercel → Settings → Environment Variables for production.
#
# Only DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL, and GEMINI_API_KEY
# are required for the app to run. Everything else is optional — each
# feature detects its own missing config and shows a clear setup message
# instead of crashing.
# ---------------------------------------------------------------------------

# --- Required ---------------------------------------------------------------

# PostgreSQL connection string (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — required for login/session.
# Generate a secret with:  openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Local: http://localhost:3000  |  Production: https://the-realty-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Gemini — primary AI provider for every AI feature (listings, market
# research, matchmaker, valuation, reports, marketing, reviews, social
# captions, etc.). Chosen as primary for lower cost. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."
# Defaults to "gemini-flash-latest" (Google's stable rolling alias, so it
# won't break as dated model IDs get retired). Override only if you want a
# specific pinned model instead, e.g. "gemini-2.5-pro" for higher quality.
# GEMINI_MODEL="gemini-flash-latest"

# --- Optional: AI fallback ---------------------------------------------------

# Anthropic Claude API — used automatically as a fallback if Gemini errors,
# rate-limits, or isn't configured. Get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: override the model (defaults to claude-haiku-4-5-20251001).
# ANTHROPIC_MODEL="claude-sonnet-5"

# --- Optional: Email sending (campaigns + automation actions) --------------

# Resend — get a key at https://resend.com/api-keys. Without a verified
# sending domain, use the sandbox default (onboarding@resend.dev).
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="The Realty App <onboarding@resend.dev>"

# --- Optional: Scheduled automation runner ----------------------------------

# Vercel automatically sends this as a Bearer token when invoking the daily
# cron job defined in vercel.json. Generate any random string.
CRON_SECRET="replace-with-a-random-string"

# --- Optional: Billing (Stripe) ---------------------------------------------

STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs for the Pro and Professional plans (create in Stripe Dashboard).
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."

# --- Optional: Specific app integrations (Phase 4) --------------------------
# Each requires registering a developer app with that platform. Slack does
# NOT need any of these — agents connect it themselves via an Incoming
# Webhook URL from inside the app (Dashboard → Connected Apps).

# ZILLOW_CLIENT_ID=""
# ZILLOW_CLIENT_SECRET=""
# DOCUSIGN_CLIENT_ID=""
# DOCUSIGN_CLIENT_SECRET=""
# META_APP_ID=""
# META_APP_SECRET=""
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
