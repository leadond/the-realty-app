generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  image         String?
  password      String?          // bcrypt hash
  phone         String?
  licenseNumber String?
  brokerage     String?
  role          UserRole         @default(USER)

  organizationId String?
  organization   Organization?   @relation("OrgMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  brokerOf       Organization?   @relation("OrgBroker")

  aiTier            AITier      @default(FREE)
  monthlyTokenLimit Int         @default(20000)
  planTier          PlanTier    @default(FREE)

  profileSlug         String?  @unique
  profileBio           String?
  profileHeadshotUrl   String?

  subscription  Subscription?
  leads         Lead[]
  showings      Showing[]
  properties    Property[]
  preferences   ClientPreference[]
  openHouses    OpenHouse[]
  checklists    ChecklistItem[]
  briefings     ShowingBriefing[]
  followUps     FollowUp[]
  documents     Document[]
  requirements  ClientRequirements[]
  propertyMatches PropertyMatch[]
  transactions  Transaction[]
  reviews       Review[]
  marketingPosts MarketingPost[]
  reports       Report[]

  aiUsage       AIUsage[]
  contracts     Contract[]       @relation("AgentContracts")
  callLogs      CallLog[]
  emailTemplates EmailTemplate[]
  emailCampaigns EmailCampaign[]
  socialAccounts SocialAccount[]
  socialPosts   SocialPost[]
  automationRules AutomationRule[]
  appConnections UserAppConnection[]
  importJobs    ImportJob[]
  sentInvites   OrgInvite[]      @relation("InviteSender")

  tasks               Task[]
  pushSubscriptions    PushSubscription[]
  webhookEndpoints     WebhookEndpoint[]
  commissionSplits     CommissionSplit[]  @relation("SplitAgent")
  smsMessages          SmsMessage[]
  agentPhoneNumber     AgentPhoneNumber?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("users")
}

enum UserRole {
  USER    // individual / demo, no org
  AGENT   // belongs to an organization
  BROKER  // owns/administers an organization
  ADMIN   // platform admin
}

enum AITier {
  FREE
  PRO
  ENTERPRISE
}

// Feature-access tier, distinct from AITier (AI token budget). Drives what
// modules a user can open, both in nav display and server-side enforcement.
// See src/lib/entitlements.ts for the single source of truth on what each
// tier unlocks.
enum PlanTier {
  FREE
  PRO
  PROFESSIONAL
  ENTERPRISE
}

// ============================================================
// ORGANIZATIONS (brokerages / teams)
// ============================================================

model Organization {
  id            String      @id @default(cuid())
  name          String
  domain        String?     @unique
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?

  members       User[]      @relation("OrgMembers")
  brokerUserId  String?     @unique
  brokerUser    User?       @relation("OrgBroker", fields: [brokerUserId], references: [id], onDelete: SetNull)

  plan          String      @default("starter") // starter, professional, enterprise
  planTier      PlanTier    @default(FREE)       // canonical tier used for feature gating
  billingStatus String      @default("active")  // active, past_due, canceled
  stripeCustomerId     String?
  stripeSubscriptionId String?

  invites       OrgInvite[]
  contracts     Contract[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("organizations")
}

model OrgInvite {
  id            String      @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email         String
  role          UserRole    @default(AGENT)
  token         String      @unique
  status        String      @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED

  invitedById   String
  invitedBy     User        @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  expiresAt     DateTime

  @@index([email])
  @@map("org_invites")
}

// ============================================================
// SUBSCRIPTIONS / BILLING (individual tier)
// ============================================================

model Subscription {
  id          String      @id @default(cuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String      // free, pro, premium, enterprise
  status      String      @default("active") // active, canceled, past_due
  startDate   DateTime    @default(now())
  endDate     DateTime?
  nextBilling DateTime?
  stripeCustomerId String?
  stripeSubscriptionId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("subscriptions")
}

// ============================================================
// AI USAGE TRACKING
// ============================================================

model AIUsage {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  model         String
  inputTokens   Int         @default(0)
  outputTokens  Int         @default(0)
  totalTokens   Int         @default(0)
  costUSD       Float       @default(0)
  feature       String?     // which page/feature triggered this call

  createdAt     DateTime    @default(now())

  @@index([userId, createdAt])
  @@map("ai_usage")
}

// ============================================================
// CRM - LEADS
// ============================================================

model Lead {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  firstName     String
  lastName      String
  email         String?
  phone         String?
  source        LeadSource  @default(WEBSITE)
  status        LeadStatus  @default(NEW)
  priority      LeadPriority @default(MEDIUM)
  budgetMin     Int?
  budgetMax     Int?
  bedrooms      Int?
  bathrooms     Int?
  propertyType  String?
  location      String?
  timeline      String? // immediate, 1-3 months, 3-6 months, 6+ months
  notes         String?
  tags          String?     // JSON array stored as string

  riskScore     Float?
  riskLevel     String?     // GREEN, YELLOW, RED
  riskWarnings  String?     // semicolon-separated

  showings      Showing[]
  contracts     Contract[]
  callLogs      CallLog[]
  smsMessages   SmsMessage[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@map("leads")
}

// ============================================================
// CALL LOG (click-to-call from the app)
// ============================================================

model CallLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  phoneNumber String
  calledAt    DateTime @default(now())
  notes       String?
  durationMin Int?

  @@index([leadId])
  @@index([userId])
  @@map("call_logs")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  OPEN_HOUSE
  COLD_CALL
  EMAIL_CAMPAIGN
  ZILLOW
  REDFIN
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ACTIVE
  NEGOTIATING
  WON
  LOST
  UNQUALIFIED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================================
// GLOBAL LEAD INTELLIGENCE (cross-org risk signals)
// ============================================================

model GlobalLeadRecord {
  id            String      @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?

  contacts      LeadContactEvent[]

  riskScore     Float       @default(0)
  contactCount  Int         @default(0)
  organizationCount Int     @default(0)

  firstContact  DateTime    @default(now())
  lastContact   DateTime    @default(now())

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
  @@index([phone])
  @@map("global_lead_records")
}

model LeadContactEvent {
  id            String      @id @default(cuid())
  globalLeadId  String
  globalLead    GlobalLeadRecord @relation(fields: [globalLeadId], references: [id], onDelete: Cascade)

  organizationId String?    // null for individual/demo users
  agentId       String

  actionType    String      // "contacted", "showed_property", "made_offer", "ghosted"

  timestamp     DateTime    @default(now())

  @@index([globalLeadId])
  @@map("lead_contact_events")
}

// ============================================================
// SHOWINGS
// ============================================================

model Showing {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  status        ShowingStatus @default(SCHEDULED)
  durationMin   Int         @default(30)
  notes         String?
  feedback      String?
  briefings     ShowingBriefing[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([leadId])
  @@map("showings")
}

enum ShowingStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================================
// PROPERTIES
// ============================================================

model Property {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  mlsId         String?     @unique
  address       String
  city          String
  state         String
  zip           String
  country       String      @default("US")
  latitude      Float?
  longitude     Float?
  price         Int
  bedrooms      Int
  bathrooms     Float
  sqft          Int?
  lotSize       Float?
  yearBuilt     Int?
  propertyType  PropertyTypeEnum
  status        PropertyListingStatus @default(ACTIVE)
  description   String?
  features      String?     // JSON array stored as string
  photos        String?     // JSON array stored as string
  virtualTourUrl String?
  openHouses    OpenHouse[]
  showings      Showing[]
  matches       PropertyMatch[]
  documents     Document[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([city, state, zip])
  @@index([organizationId])
  @@index([userId])
  @@map("properties")
}

enum PropertyTypeEnum {
  SINGLE_FAMILY
  CONDO
  TOWNHOUSE
  MULTI_FAMILY
  LAND
  MOBILE_HOME
  COMMERCIAL
  RANCH
  OTHER
}

enum PropertyListingStatus {
  ACTIVE
  PENDING
  SOLD
  OFF_MARKET
  COMING_SOON
}

// ============================================================
// CLIENT PREFERENCES
// ============================================================

model ClientPreference {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  preferenceType PreferenceType
  category      String      // location, style, amenity, budget, school, commute
  value         String
  weight        Float       @default(1.0) // importance weight 0-1
  isMustHave    Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("client_preferences")
}

enum PreferenceType {
  MUST_HAVE
  NICE_TO_HAVE
  DEAL_BREAKER
  NEUTRAL
}

// ============================================================
// OPEN HOUSES
// ============================================================

model OpenHouse {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  status        OpenHouseStatus @default(UPCOMING)
  description   String?
  specialInstructions String?
  expectedAttendance Int    @default(0)
  visitors      Visitor[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@map("open_houses")
}

enum OpenHouseStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Visitor {
  id            String      @id @default(cuid())
  openHouseId   String
  openHouse     OpenHouse   @relation(fields: [openHouseId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  email         String?
  phone         String?
  isRegistered  Boolean     @default(false)
  interestLevel InterestLevel @default(NEUTRAL)
  notes         String?
  followUpNeeded Boolean    @default(false)
  followUpDate  DateTime?
  signedInAt    DateTime?
  createdAt     DateTime    @default(now())

  @@map("visitors")
}

enum InterestLevel {
  VERY_INTERESTED
  INTERESTED
  NEUTRAL
  NOT_INTERESTED
  JUST_BROWSING
}

// ============================================================
// CHECKLISTS
// ============================================================

model ChecklistItem {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  isCompleted   Boolean     @default(false)
  dueDate       DateTime?
  completedAt   DateTime?
  category      String      // listing, buying, selling, closing, marketing
  priority      Int         @default(0)
  orderId       Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("checklist_items")
}

// ============================================================
// SHOWING BRIEFINGS (AI-generated)
// ============================================================

model ShowingBriefing {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  showingId     String
  showing       Showing     @relation(fields: [showingId], references: [id], onDelete: Cascade)
  content       String      // AI-generated briefing text
  highlights    String?     // JSON array stored as string
  talkingPoints String?     // JSON array stored as string
  competitorAnalysis String?
  generatedAt   DateTime    @default(now())

  @@map("showing_briefings")
}

// ============================================================
// FOLLOW-UPS
// ============================================================

model FollowUp {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  subject       String
  type          FollowUpType @default(EMAIL)
  status        FollowUpStatus @default(PENDING)
  scheduledFor  DateTime
  completedAt   DateTime?
  content       String?
  notes         String?
  reminderSent  Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("follow_ups")
}

enum FollowUpType {
  EMAIL
  PHONE
  TEXT
  MEETING
  MAIL
  OTHER
}

enum FollowUpStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  OVERDUE
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId    String?
  property      Property?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name          String
  type          DocumentType
  url           String
  size          Int         // bytes
  mimeType      String?
  isShared      Boolean     @default(false)
  sharedWith    String?     // email or user ID
  tags          String?     // JSON array stored as string
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("documents")
}

enum DocumentType {
  DISCLOSURE
  CONTRACT
  INSPECTION
  APPRAISAL
  MORTGAGE
  INSURANCE
  TAX
  PHOTO
  FLYER
  OTHER
}

// ============================================================
// CLIENT REQUIREMENTS (AI matching input)
// ============================================================

model ClientRequirements {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  budgetRange   String?     // "$300k-$500k"
  desiredLocations String?  // JSON array stored as string
  bedrooms      Int?
  bathrooms     Int?
  minSqft       Int?
  maxSqft       Int?
  propertyTypes String?     // JSON array of PropertyTypeEnum values
  mustHaveFeatures String?  // JSON array stored as string
  dealBreakers  String?     // JSON array stored as string
  timeline      String?
  specialNeeds  String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("client_requirements")
}

// ============================================================
// PROPERTY MATCHES (AI-generated recommendations)
// ============================================================

model PropertyMatch {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leadId        String?
  matchScore    Float       // 0-100
  matchReason   String      // AI-generated explanation
  matchedAt     DateTime    @default(now())
  isViewed      Boolean     @default(false)
  viewedAt      DateTime?

  @@map("property_matches")
}

// ============================================================
// NEIGHBORHOOD DATA (AI-enriched)
// ============================================================

model NeighborhoodData {
  id            String      @id @default(cuid())
  name          String
  city          String
  state         String
  zip           String?
  medianPrice   Int?
  priceTrend    Float?      // percent change
  daysOnMarket  Int?
  schoolRating  Float?      // 0-10
  crimeRating   Float?      // 0-10 (higher = safer)
  walkScore     Int?        // 0-100
  transitScore  Int?
  demographics  String?     // JSON string
  amenities     Amenity[]
  description   String?     // AI-generated neighborhood overview
  lastUpdated   DateTime    @default(now())

  @@unique([name, city, state])
  @@map("neighborhood_data")
}

model Amenity {
  id            String      @id @default(cuid())
  neighborhoodId String
  neighborhood  NeighborhoodData @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  name          String
  category      String      // park, school, restaurant, shopping, transit, hospital
  distance      Float?      // miles
  rating        Float?
  description   String?

  @@map("amenities")
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  leadId        String?
  propertyId    String?
  type          TransactionType @default(PURCHASE)
  status        TransactionStatus @default(INITIATED)
  price         Int?
  closingDate   DateTime?
  commission    Float?
  commissionRate Float?     // percentage
  agentNotes    String?
  checklist     TransactionChecklist[]
  documents     Document[]
  commissionSplits CommissionSplit[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@map("transactions")
}

enum TransactionType {
  PURCHASE
  SALE
  RENTAL
  REFINANCE
}

enum TransactionStatus {
  INITIATED
  UNDER_CONTRACT
  IN_ESCROW
  INSPECTION
  FINANCING
  NEGOTIATING_REPAIRS
  PRE_CLOSING
  CLOSED
  FALLING_THROUGH
  CANCELLED
}

model TransactionChecklist {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  isCompleted   Boolean     @default(false)
  dueDate       DateTime?
  completedAt   DateTime?
  category      String      // paperwork, inspection, financing, closing
  orderId       Int         @default(0)
  createdAt     DateTime    @default(now())

  @@map("transaction_checklists")
}

// ============================================================
// REVIEWS & TESTIMONIALS
// ============================================================

model Review {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  rating        Int         // 1-5
  title         String?
  content       String
  platform      String?     // google, zillow, facebook, etc.
  isPublished   Boolean     @default(false)
  publishedUrl  String?
  aiSummary     String?     // AI-generated summary
  sentiment     String?     // positive, neutral, negative
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("reviews")
}

// ============================================================
// MARKETING POSTS (one-off AI-generated copy, Phase 1)
// ============================================================

model MarketingPost {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId    String?
  content       String
  platform      MarketingPlatform
  status        MarketingStatus @default(DRAFT)
  scheduledFor  DateTime?
  publishedAt   DateTime?
  engagementMetrics String? // JSON string with likes, shares, comments
  aiGenerated   Boolean     @default(true)
  imageUrl      String?
  hashtags      String?     // JSON array stored as string
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("marketing_posts")
}

enum MarketingPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  ZILLOW
  REDFIN
  EMAIL
  WEBSITE
  OTHER
}

enum MarketingStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  ARCHIVED
}

// ============================================================
// REPORTS (AI-generated analytics)
// ============================================================

model Report {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  type          ReportType
  content       String      // AI-generated report content
  summary       String?
  dataRange     String?     // "last-30-days", "this-quarter", etc.
  filters       String?     // JSON string of applied filters
  generatedAt   DateTime    @default(now())
  isStarred     Boolean     @default(false)

  @@map("reports")
}

enum ReportType {
  SALES_PERFORMANCE
  LEAD_ANALYSIS
  MARKET_TRENDS
  COMPARATIVE_MARKET_ANALYSIS
  CLIENT_ACTIVITY
  REVENUE_SUMMARY
  CUSTOM
}

// ============================================================
// CONTRACTS & E-SIGNATURE (self-hosted, no external provider)
// ============================================================

model Contract {
  id            String      @id @default(cuid())
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  agentId       String
  agent         User        @relation("AgentContracts", fields: [agentId], references: [id], onDelete: Cascade)

  leadId        String?
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  type          ContractType
  title         String
  buyerName     String
  buyerEmail    String?
  content       String      // rendered contract text (from template + variables)
  documentUrl   String?     // generated PDF, base64 or storage URL

  signatures    ContractSignature[]

  status        ContractStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  signedAt      DateTime?
  expiresAt     DateTime?

  @@index([organizationId])
  @@index([agentId])
  @@map("contracts")
}

enum ContractType {
  BUYER_REPRESENTATION
  SELLER_REPRESENTATION
  DUAL_AGENCY
  COMMISSION_AGREEMENT
  INSPECTION_WAIVER
  CONTINGENCY_REMOVAL
  EARNEST_MONEY
  CUSTOM
}

enum ContractStatus {
  DRAFT
  SENT_FOR_SIGNATURE
  PARTIALLY_SIGNED
  SIGNED
  REJECTED
  EXPIRED
  ARCHIVED
}

model ContractSignature {
  id            String      @id @default(cuid())
  contractId    String
  contract      Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  signer        String
  email         String
  role          String      // buyer, seller, agent, witness

  signatureData String?     // base64 PNG of drawn signature
  signedAt      DateTime?
  ipAddress     String?

  @@map("contract_signatures")
}

// ============================================================
// EMAIL MARKETING (Phase 2A)
// ============================================================

model EmailTemplate {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  subject       String
  body          String      // HTML or plain text with {{placeholders}}
  category      String?     // new-listing, open-house, follow-up, market-update, holiday, custom

  campaigns     EmailCampaign[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("email_templates")
}

model EmailCampaign {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  name          String
  subject       String
  body          String
  segment       String      // JSON filter: {"status": "QUALIFIED"} etc, stored as string

  status        String      @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, FAILED
  scheduledFor  DateTime?
  sentAt        DateTime?

  sends         EmailSend[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("email_campaigns")
}

model EmailSend {
  id            String      @id @default(cuid())
  campaignId    String
  campaign      EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  leadId        String?
  recipientEmail String
  status        String      @default("PENDING") // PENDING, SENT, FAILED, OPENED, CLICKED, BOUNCED
  providerMessageId String?
  errorMessage  String?

  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?

  @@index([campaignId])
  @@map("email_sends")
}

// ============================================================
// SOCIAL MEDIA SCHEDULING (Phase 2B)
// ============================================================

model SocialAccount {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform      String      // facebook, instagram, tiktok, linkedin
  accountName   String?
  accessToken   String?     // encrypted / env-gated, null until OAuth configured
  refreshToken  String?
  tokenExpires  DateTime?
  isConnected   Boolean     @default(false)

  posts         SocialPost[]
  createdAt     DateTime    @default(now())

  @@unique([userId, platform])
  @@map("social_accounts")
}

model SocialPost {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  socialAccountId String?
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  propertyId    String?
  platform      String      // facebook, instagram, tiktok, linkedin
  caption       String
  imageUrl      String?

  status        String      @default("DRAFT") // DRAFT, SCHEDULED, POSTED, FAILED
  scheduledFor  DateTime?
  postedAt      DateTime?
  externalPostId String?
  errorMessage  String?

  engagementLikes Int       @default(0)
  engagementComments Int    @default(0)
  engagementShares Int      @default(0)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, scheduledFor])
  @@map("social_posts")
}

// ============================================================
// LEAD FOLLOW-UP AUTOMATION (Phase 2C)
// ============================================================

model AutomationRule {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  isActive      Boolean     @default(true)

  triggerType   String      // lead_status_changed, showing_scheduled, no_response_days, open_house_visitor
  triggerConfig String      // JSON string, e.g. {"status":"CONTACTED"} or {"days":5}

  actionType    String      // send_email, create_reminder, send_sms (sms not wired without provider)
  actionConfig  String      // JSON string, e.g. {"templateId":"..."} or {"message":"..."}

  executions    AutomationExecution[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("automation_rules")
}

model AutomationExecution {
  id            String      @id @default(cuid())
  ruleId        String
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  leadId        String?
  status        String      @default("PENDING") // PENDING, EXECUTED, FAILED, SKIPPED
  result        String?

  executedAt    DateTime    @default(now())

  @@index([ruleId])
  @@map("automation_executions")
}

// ============================================================
// APP INTEGRATION FRAMEWORK (Phase 3 + 4)
// ============================================================

model AppIntegration {
  id                String   @id @default(cuid())
  name              String   @unique  // "zillow", "docusign", "slack", "csv"
  displayName       String
  description       String
  category          String   // data, signature, email, social, notification

  oauthProvider     String?
  oauthAuthorizeUrl String?
  oauthTokenUrl     String?
  oauthScopes       String[] @default([])

  canImport         Boolean  @default(false)
  canSync           Boolean  @default(false)
  requiresCredentials Boolean @default(true) // false for CSV, which needs no external account

  isActive          Boolean  @default(true)
  supportLevel      String   @default("BETA") // OFFICIAL, BETA, COMMUNITY

  connections       UserAppConnection[]
  importJobs        ImportJob[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("app_integrations")
}

model UserAppConnection {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  integrationId     String
  integration       AppIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  accessToken       String?  // encrypted at rest recommended for prod; env-gated for now
  refreshToken      String?
  tokenExpires      DateTime?
  webhookUrl        String?  // for Slack-style incoming webhooks (no OAuth needed)

  isActive          Boolean  @default(true)
  lastSyncAt        DateTime?
  syncStatus        String   @default("IDLE") // IDLE, SYNCING, ERROR, SUCCESS
  syncError         String?

  connectedAt       DateTime @default(now())
  disconnectedAt    DateTime?

  @@unique([userId, integrationId])
  @@map("user_app_connections")
}

model ImportMap {
  id                String   @id @default(cuid())
  targetModel       String   // "Lead", "Property"
  externalField     String
  yourField         String
  fallbackValue     String?

  @@map("import_maps")
}

model ImportJob {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  integrationId     String?
  integration       AppIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  status            String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  sourceType        String   @default("manual_csv")
  totalRecords      Int      @default(0)
  recordsImported   Int      @default(0)
  recordsSkipped    Int      @default(0)
  recordsErrored    Int      @default(0)

  errors            ImportError[]

  startedAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([userId, status])
  @@map("import_jobs")
}

model ImportError {
  id                String   @id @default(cuid())
  jobId             String
  job               ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  recordNumber      Int
  errorMessage      String

  createdAt         DateTime @default(now())

  @@index([jobId])
  @@map("import_errors")
}

// ============================================================
// TASKS (free-form to-do list, FREE tier)
// ============================================================

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  notes       String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("tasks")
}

// ============================================================
// PUSH NOTIFICATIONS (PRO tier)
// ============================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ============================================================
// OUTGOING WEBHOOKS (ENTERPRISE tier)
// ============================================================

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  events    String   // comma-separated: lead.created,showing.scheduled,contract.signed
  secret    String   // HMAC signing key for payload verification on the receiving end
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("webhook_endpoints")
}

// ============================================================
// COMMISSION SPLITS (PROFESSIONAL tier)
// ============================================================

model CommissionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  agentId       String
  agent         User        @relation("SplitAgent", fields: [agentId], references: [id], onDelete: Cascade)
  role          String      // REFERRING, CO_LISTING, CO_BUYING, TRANSACTION_COORDINATOR
  splitPercent  Float
  splitAmount   Float?
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@map("commission_splits")
}

// ============================================================
// SMS MESSAGING (PRO tier, Twilio-gated)
// ============================================================

model SmsMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   String   // OUTBOUND, INBOUND
  body        String
  fromNumber  String
  toNumber    String
  status      String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED, RECEIVED
  twilioSid   String?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([userId])
  @@map("sms_messages")
}

model AgentPhoneNumber {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber   String   @unique // E.164 format
  twilioSid     String
  provisionedAt DateTime @default(now())

  @@map("agent_phone_numbers")
}
